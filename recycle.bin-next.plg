<!--
Get the plugin bundle.
-->
<FILE Name="/boot/config/plugins/&plugin;/&name;-&version;.tgz">
<URL>"&tgzURL;/&name;-&version;.tgz"</URL>
<MD5>&MD5;</MD5>
</FILE>

<!--
The 'pre-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# The previous recycle bin plugin cannot be installed.
#
if [ -f /boot/config/plugins/&plugin;.plg ] ; then
echo ""
echo "-----------------------------------------------------------"
echo " &name; has not been installed!"
echo ""
echo " The previous Recycle Bin plugin is installed."
echo ""
echo " You must uninstall the Recycle Bin plugin"
echo " before installing Recycle Bin - Next."
echo ""
echo "-----------------------------------------------------------"
echo ""
exit 1
fi

#
# Stop recycle bin.
#
echo "Stopping Recycle Bin..."

/usr/local/emhttp/plugins/&plugin;/scripts/rc.&plugin; stop 2>/dev/null

#
# Remove recycle bin cron file.
#
rm -f /boot/config/plugins/dynamix/recyclebin.cron

#
# Remove emhttp files so we can re-install.
#
rm -rf /usr/local/emhttp/plugins/&plugin;/* 2>/dev/null

#
# Remove old 'bundle' files.
#
rm -f $(ls /boot/config/plugins/&plugin;/&name;*.tgz 2>/dev/null | grep -v '&version;')
</INLINE>
</FILE>

<!--
Install the plugin bundle.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Install the 'bundle'.
#
tar -xf /boot/config/plugins/&plugin;/&name;-&version;.tgz -C /usr/local/emhttp/plugins 2>/dev/null
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/&plugin;/&plugin;.cfg">
<INLINE>
<![CDATA[
SERVICE="disable"
HIDE_FOLDER="no"
BACKGROUND="yes"
DIR_MODE=""
PARAMETERS=""
EXCLUDE=""
EXCLUDE_DIRS=""
EXCLUDE_SHARES="appdata,docker,domains,syslog,system"
SCHEDRUN="no"
AGE="7"
NOTIFY="no"
LOG="yes"
INCLUDE_UD="no"
]]>
</INLINE>
</FILE>

<!--
The 'post-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Create /tmp/ directory.
#
mkdir -p /tmp/&plugin;/

#
# Fix permissions of executable files
#
chmod +x /usr/local/emhttp/plugins/&plugin;/scripts/* /usr/local/emhttp/plugins/&plugin;/event/*

#
# Create symlink for the cli recycle delete
#
ln -sf /usr/local/emhttp/plugins/recycle.bin/scripts/recycle-delete /usr/local/sbin/recycle-delete

#
# Start recycle bin.
#
echo "Starting Recycle Bin..."

at -f "/usr/local/emhttp/plugins/&plugin;/event/started" "now" 2>/dev/null

#
# Set the version of the plugin for the recycle bin page notification.
#
echo -n "&version;" > "/tmp/&plugin;/recycle_bin_version"

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been installed."
echo " Copyright 2015-2026 &author;"
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
#
# Stop recycle bin in the background.
#
/usr/local/emhttp/plugins/&plugin;/scripts/rc.&plugin; stop 2>/dev/null

#
# Remove plugin files from emhttp.
#
rm -rf /usr/local/emhttp/plugins/&plugin; 2>/dev/null

#
# Remove the recycle bin bundle so it will be downloaded if re-installed.
#
rm -rf /boot/config/plugins/&plugin;/&name;-&version;.tgz

#
# Remove RecycleBin browse symlinks.
#
rm -rf /mnt/RecycleBin

#
# Remove the recycle delete symlink
#
rm -f /usr/local/sbin/recycle-delete

#
# Remove the pid file.
#
rm -rf /var/run/&plugin;.pid 2>/dev/null

#
# Remove the tmp directory.
#
rm -rf /tmp/&plugin; 2>/dev/null

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been removed."
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

</PLUGIN>
